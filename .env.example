# Copy to .env and fill in values. Never commit .env.

# ---------------------------------------------------------------------------
# Mobile app (Flutter) on the same Wi‑Fi as this Mac
# ---------------------------------------------------------------------------
# The app uses API_BASE_URL (see frontend/dart_defines/ios_device.json), e.g.:
#   API_BASE_URL=http://192.168.1.170:3000
# Replace the IP with your Mac's LAN IP (run: ipconfig getifaddr en0).
# This backend does not read API_BASE_URL — it only needs to listen on all interfaces.
# `npm run dev` uses --hostname 0.0.0.0 -p 3000 so the phone can reach you at that URL.
# If OAuth redirects must match, set GOOGLE_REDIRECT_URI to the same host + /api/... path.

JWT_SECRET="change-me-in-production"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Example: http://localhost:3000/api/integrations/gmail/callback
GOOGLE_REDIRECT_URI=""

# ---------------------------------------------------------------------------
# Option A — Local Postgres (docker-compose in repo root: ../docker-compose.yml)
# ---------------------------------------------------------------------------
# DATABASE_URL="postgresql://exmind:exmind@localhost:5432/exmind?schema=public"
# DATABASE_URL_UNPOOLED="postgresql://exmind:exmind@localhost:5432/exmind?schema=public"

# ---------------------------------------------------------------------------
# Option B — Supabase Postgres + Prisma
# ---------------------------------------------------------------------------
# If Prisma reports P1001 to db.<project>.supabase.co:5432: direct DB is IPv6-only; use the pooler URI
# from the dashboard instead (Connect → Session pooler). See:
# https://supabase.com/docs/guides/database/connecting-to-postgres
#
# In the Supabase dashboard: Project → Connect (or Settings → Database).
# Prisma guide: https://supabase.com/docs/guides/database/prisma
#
# This repo’s Prisma schema uses:
#   url       = DATABASE_URL        → use pooler TRANSACTION mode (port 6543)
#   directUrl = DATABASE_URL_UNPOOLED → use pooler SESSION mode (5432) or direct DB URL
#
# Example shape (replace [PROJECT-REF], region host, and password from the dashboard):
#
# DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
# DATABASE_URL_UNPOOLED="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require"
#
# Optional: create a dedicated DB user "prisma" (SQL in Supabase docs) instead of postgres.

# Default below matches local docker-compose; override in your real .env
DATABASE_URL="postgresql://exmind:exmind@localhost:5432/exmind?schema=public"
DATABASE_URL_UNPOOLED="postgresql://exmind:exmind@localhost:5432/exmind?schema=public"
